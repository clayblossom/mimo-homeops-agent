# MiMo HomeOps Agent Pro — Environment Variables

# API Server
API_HOST=0.0.0.0
API_PORT=8700
DEBUG=true

# MiMo / LLM (leave empty to use heuristic planner)
MIMO_API_BASE=https://api.openai.com/v1
MIMO_API_KEY=
MIMO_MODEL=mimo-7b

# Home Assistant (optional)
HA_URL=
HA_TOKEN=
HA_DRY_RUN=true

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Safety
CONFIRM_SENSITIVE=true
